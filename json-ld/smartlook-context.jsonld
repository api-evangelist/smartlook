{
  "@context": {
    "@version": 1.1,
    "sl": "https://integrations.smartlook.com/vocab#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Visitor": "sl:Visitor",
    "Session": "sl:Session",
    "Event": "sl:Event",
    "Funnel": "sl:Funnel",
