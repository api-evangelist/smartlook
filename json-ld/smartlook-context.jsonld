    "updatedAt": { "@id": "sl:updatedAt", "@type": "xsd:dateTime" },
    "lastResponseAt": { "@id": "sl:lastResponseAt", "@type": "xsd:dateTime" },

    "duration": { "@id": "sl:duration", "@type": "xsd:integer" },
